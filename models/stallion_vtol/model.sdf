<?xml version="1.0"?>
<sdf version="1.9">
  <model name="stallion_vtol">
    <pose>0 0 0.2 0 0 0</pose>

    <!-- ============ Fuselage + wing + tail (FLU gz convention: +Y=LEFT) ============
         Stallion V2 MTOW 3.10 kg = 2.65 base + 3x0.085 rotors
                                  + 2x0.04 tilt arms + 2x0.025 ailerons + 2x0.03 vtails.
         Rotor positions (PX4 body FRD): motor 1 right PY=+0.82; SDF mirrors to y=-0.82.
    -->
    <link name="base_link">
      <inertial>
        <!-- Stallion V2 gövde inertia per user-specified values:
             Solid box approximation, L×b×h = 0.90×1.34×0.16 m, mass 3.1 kg
               Ixx = m/12×(b²+h²) = 0.4705
               Iyy = m/12×(L²+h²) = 0.2159
               Izz = m/12×(L²+b²) = 0.6731
             Base_link absorbs the full MTOW (3.1 kg) inertia in this box model;
             non-base_link links (rotors/servos) keep their small masses for
             parallel-axis contribution but the box already captures bulk. -->
        <mass>2.65</mass>
        <inertia>
          <ixx>0.4705</ixx><iyy>0.2159</iyy><izz>0.6731</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="fuselage_col">
        <geometry><box><size>1.6 0.25 0.20</size></box></geometry>
      </collision>
      <visual name="fuselage_vis">
        <geometry><box><size>1.6 0.25 0.20</size></box></geometry>
        <material><ambient>0.15 0.15 0.18 1</ambient><diffuse>0.25 0.25 0.28 1</diffuse></material>
      </visual>
      <!-- Wing: Stallion V2 (chord 0.211 m, span 1.34 m, area 0.265 m²) -->
      <visual name="wing_vis">
        <pose>0.30 0 0.00 0 0 0</pose>
        <geometry><box><size>0.211 1.34 0.022</size></box></geometry>
        <material><ambient>0.9 0.9 0.9 1</ambient><diffuse>0.95 0.95 0.95 1</diffuse></material>
      </visual>
      <collision name="wing_col">
        <pose>0.30 0 0 0 0 0</pose>
        <geometry><box><size>0.211 1.34 0.022</size></box></geometry>
      </collision>
      <!-- Tail boom -->
      <visual name="tailboom_vis">
        <pose>-0.60 0 0.02 0 0 0</pose>
        <geometry><box><size>0.80 0.05 0.05</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient></material>
      </visual>
      <!-- V-tail static fins (angled +/-35 deg about X) -->
      <visual name="vtail_L_static_vis">
        <pose>-0.95 0.14 0.08 0.3491 0 0</pose>
        <geometry><box><size>0.18 0.30 0.02</size></box></geometry>
        <material><ambient>0.85 0.85 0.85 1</ambient></material>
      </visual>
      <visual name="vtail_R_static_vis">
        <pose>-0.95 -0.14 0.08 -0.3491 0 0</pose>
        <geometry><box><size>0.18 0.30 0.02</size></box></geometry>
        <material><ambient>0.85 0.85 0.85 1</ambient></material>
      </visual>

      <!-- Air pressure (altimeter) -->
      <sensor name="air_pressure_sensor" type="air_pressure">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <air_pressure>
          <pressure>
            <noise type="gaussian"><mean>0</mean><stddev>3</stddev></noise>
          </pressure>
        </air_pressure>
      </sensor>
      <!-- Magnetometer -->
      <sensor name="magnetometer_sensor" type="magnetometer">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <magnetometer>
          <x><noise type="gaussian"><stddev>0.0001</stddev></noise></x>
          <y><noise type="gaussian"><stddev>0.0001</stddev></noise></y>
          <z><noise type="gaussian"><stddev>0.0001</stddev></noise></z>
        </magnetometer>
      </sensor>
      <!-- IMU -->
      <sensor name="imu_sensor" type="imu">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>250</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.00637</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.00637</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.00686</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
      <!-- GNSS -->
      <sensor name="navsat_sensor" type="navsat">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
      </sensor>
    </link>

    <!-- ==================== Airspeed sensor link ====================
         PX4 gz_bridge subscribes to /world/<world>/model/<model>/link/airspeed_link/
         sensor/air_speed/air_speed — required for VTOL transition gating against
         stall speed (rather than time-based-only fallback).
    -->
    <link name="airspeed_link">
      <pose>0.40 0 0.05 0 0 0</pose>
      <inertial>
        <mass>0.001</mass>
        <inertia><ixx>1e-7</ixx><iyy>1e-7</iyy><izz>1e-7</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <sensor name="air_speed" type="air_speed">
        <always_on>1</always_on>
        <update_rate>20</update_rate>
        <air_speed>
          <pressure>
            <noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise>
          </pressure>
        </air_speed>
      </sensor>
    </link>
    <joint name="airspeed_joint" type="fixed">
      <parent>base_link</parent>
      <child>airspeed_link</child>
    </joint>

    <!-- ==================== Front RIGHT rotor 0 (CW, PX4 +PY → gz -Y) ==================== -->
    <link name="tilt_arm_R">
      <pose>0.44 -0.82 0.05 0 0 0</pose>
      <inertial>
        <mass>0.04</mass>
        <inertia><ixx>3e-5</ixx><iyy>3e-5</iyy><izz>3e-5</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="tilt_arm_R_vis">
        <geometry><cylinder><radius>0.025</radius><length>0.08</length></cylinder></geometry>
        <pose>0 0 0 0 1.5708 0</pose>
        <material><ambient>0.4 0.4 0.4 1</ambient></material>
      </visual>
    </link>
    <joint name="tilt_joint_R" type="revolute">
      <parent>base_link</parent>
      <child>tilt_arm_R</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>0</lower><upper>1.5708</upper>
               <effort>10</effort><velocity>3</velocity></limit>
        <dynamics><damping>0.05</damping></dynamics>
      </axis>
    </joint>
    <link name="rotor_0">
      <pose>0.44 -0.82 0.09 0 0 0</pose>
      <inertial>
        <!-- T-Motor F90 28065 1300KV (~80g) + HQProp 7x4x3 tri-blade (~5g) -->
        <mass>0.085</mass>
        <inertia><ixx>3.5e-5</ixx><iyy>3.5e-5</iyy><izz>3.0e-5</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="rotor_0_vis">
        <geometry><box><size>0.178 0.020 0.005</size></box></geometry>
        <material><ambient>0.9 0.2 0.2 1</ambient></material>
      </visual>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>tilt_arm_R</parent>
      <child>rotor_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.002</damping></dynamics>
      </axis>
    </joint>

    <!-- ==================== Front LEFT rotor 1 (CCW, PX4 -PY → gz +Y) ==================== -->
    <link name="tilt_arm_L">
      <pose>0.44 0.82 0.05 0 0 0</pose>
      <inertial>
        <mass>0.04</mass>
        <inertia><ixx>3e-5</ixx><iyy>3e-5</iyy><izz>3e-5</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="tilt_arm_L_vis">
        <geometry><cylinder><radius>0.025</radius><length>0.08</length></cylinder></geometry>
        <pose>0 0 0 0 1.5708 0</pose>
        <material><ambient>0.4 0.4 0.4 1</ambient></material>
      </visual>
    </link>
    <joint name="tilt_joint_L" type="revolute">
      <parent>base_link</parent>
      <child>tilt_arm_L</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>0</lower><upper>1.5708</upper>
               <effort>10</effort><velocity>3</velocity></limit>
        <dynamics><damping>0.05</damping></dynamics>
      </axis>
    </joint>
    <link name="rotor_1">
      <pose>0.44 0.82 0.09 0 0 0</pose>
      <inertial>
        <mass>0.085</mass>
        <inertia><ixx>3.5e-5</ixx><iyy>3.5e-5</iyy><izz>3.0e-5</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="rotor_1_vis">
        <geometry><box><size>0.178 0.020 0.005</size></box></geometry>
        <material><ambient>0.2 0.2 0.9 1</ambient></material>
      </visual>
    </link>
    <joint name="rotor_1_joint" type="revolute">
      <parent>tilt_arm_L</parent>
      <child>rotor_1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.002</damping></dynamics>
      </axis>
    </joint>

    <!-- ==================== Tail rotor 2 (CCW, fixed vertical) ==================== -->
    <link name="rotor_2">
      <pose>-1.00 0 0.12 0 0 0</pose>
      <inertial>
        <mass>0.085</mass>
        <inertia><ixx>3.5e-5</ixx><iyy>3.5e-5</iyy><izz>3.0e-5</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="rotor_2_vis">
        <geometry><box><size>0.178 0.020 0.005</size></box></geometry>
        <material><ambient>0.2 0.9 0.2 1</ambient></material>
      </visual>
    </link>
    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_2</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.002</damping></dynamics>
      </axis>
    </joint>

    <!-- ==================== Aileron L (left wing, SDF +Y) ==================== -->
    <link name="aileron_L">
      <pose>0.25 0.65 0.00 0 0 0</pose>
      <inertial>
        <mass>0.025</mass>
        <inertia><ixx>5e-5</ixx><iyy>5e-5</iyy><izz>5e-5</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="aileron_L_vis">
        <geometry><box><size>0.08 0.40 0.015</size></box></geometry>
        <material><ambient>0.6 0.6 0.2 1</ambient></material>
      </visual>
    </link>
    <joint name="aileron_L_joint" type="revolute">
      <parent>base_link</parent>
      <child>aileron_L</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-0.5236</lower><upper>0.5236</upper>
               <effort>5</effort><velocity>5</velocity></limit>
        <dynamics><damping>0.02</damping></dynamics>
      </axis>
    </joint>

    <!-- ==================== Aileron R (right wing, SDF -Y) ==================== -->
    <link name="aileron_R">
      <pose>0.25 -0.65 0.00 0 0 0</pose>
      <inertial>
        <mass>0.025</mass>
        <inertia><ixx>5e-5</ixx><iyy>5e-5</iyy><izz>5e-5</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="aileron_R_vis">
        <geometry><box><size>0.08 0.40 0.015</size></box></geometry>
        <material><ambient>0.6 0.6 0.2 1</ambient></material>
      </visual>
    </link>
    <joint name="aileron_R_joint" type="revolute">
      <parent>base_link</parent>
      <child>aileron_R</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-0.5236</lower><upper>0.5236</upper>
               <effort>5</effort><velocity>5</velocity></limit>
        <dynamics><damping>0.02</damping></dynamics>
      </axis>
    </joint>

    <!-- ==================== V-tail L ruddervator (left, SDF +Y, roll +35°) ==================== -->
    <link name="vtail_L">
      <pose>-1.02 0.22 0.14 0.3491 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia><ixx>5e-5</ixx><iyy>5e-5</iyy><izz>5e-5</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="vtail_L_vis">
        <geometry><box><size>0.08 0.35 0.015</size></box></geometry>
        <material><ambient>0.6 0.2 0.6 1</ambient></material>
      </visual>
    </link>
    <joint name="vtail_L_joint" type="revolute">
      <parent>base_link</parent>
      <child>vtail_L</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-0.5236</lower><upper>0.5236</upper>
               <effort>5</effort><velocity>5</velocity></limit>
        <dynamics><damping>0.02</damping></dynamics>
      </axis>
    </joint>

    <!-- ==================== V-tail R ruddervator (right, SDF -Y, roll -35°) ==================== -->
    <link name="vtail_R">
      <pose>-1.02 -0.22 0.14 -0.3491 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia><ixx>5e-5</ixx><iyy>5e-5</iyy><izz>5e-5</izz>
                 <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="vtail_R_vis">
        <geometry><box><size>0.08 0.35 0.015</size></box></geometry>
        <material><ambient>0.6 0.2 0.6 1</ambient></material>
      </visual>
    </link>
    <joint name="vtail_R_joint" type="revolute">
      <parent>base_link</parent>
      <child>vtail_R</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-0.5236</lower><upper>0.5236</upper>
               <effort>5</effort><velocity>5</velocity></limit>
        <dynamics><damping>0.02</damping></dynamics>
      </axis>
    </joint>

    <!-- ==================== Motor plugins ====================
         PX4 gz_bridge publishes single gz::msgs::Actuators on
         /stallion_vtol/command/motor_speed with velocity[motorNumber].
         F90 28065 1300KV + HQProp 7x4x3 @ 6S: max thrust 20.11 N per motor.
         motorConstant = 20.11 / 2300² = 3.80e-6
    -->
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>2500</maxRotVelocity>
      <motorConstant>3.80e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <!-- CCW matches CA_ROTOR1_KM=+0.05 (PX4 convention +KM = CCW).
           rotor_0 (cw) and rotor_2 (ccw) render correctly with identical
           SDF structure, so this should too after a clean rebuild. -->
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>2500</maxRotVelocity>
      <motorConstant>3.80e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>2500</maxRotVelocity>
      <motorConstant>3.80e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>2</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <!-- ==================== Joint position controllers ====================
         PX4 gz_bridge publishes Double on /model/stallion_vtol/servo_N.
         CA_AIRFRAME=3 order: control surfaces (1..4) then tilts (5..6).
         servo_0 aileron L | servo_1 aileron R | servo_2 vtail L | servo_3 vtail R
         servo_4 tilt R    | servo_5 tilt L
    -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>aileron_L_joint</joint_name>
      <sub_topic>servo_0</sub_topic>
      <p_gain>3</p_gain><i_gain>0</i_gain><d_gain>0.05</d_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>aileron_R_joint</joint_name>
      <sub_topic>servo_1</sub_topic>
      <p_gain>3</p_gain><i_gain>0</i_gain><d_gain>0.05</d_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>vtail_L_joint</joint_name>
      <sub_topic>servo_2</sub_topic>
      <p_gain>3</p_gain><i_gain>0</i_gain><d_gain>0.05</d_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>vtail_R_joint</joint_name>
      <sub_topic>servo_3</sub_topic>
      <p_gain>3</p_gain><i_gain>0</i_gain><d_gain>0.05</d_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>tilt_joint_R</joint_name>
      <sub_topic>servo_4</sub_topic>
      <p_gain>5</p_gain><i_gain>0</i_gain><d_gain>0.1</d_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>tilt_joint_L</joint_name>
      <sub_topic>servo_5</sub_topic>
      <p_gain>5</p_gain><i_gain>0</i_gain><d_gain>0.1</d_gain>
    </plugin>

    <!-- ==================== Wing aerodynamics ====================
         Stallion V2 wing: Eppler E205, chord 0.211 m, span 1.34 m, area 0.265 m².
         3D lift slope cla = 2πAR/(AR+2) = 4.86 (AR=6.8).
         Zero-lift α = -3.2° = -0.056 rad (E205 polar).
         Stall at 11° = 0.192 rad.
    -->
    <plugin filename="gz-sim-lift-drag-system"
            name="gz::sim::systems::LiftDrag">
      <air_density>1.2041</air_density>
      <cla>4.86</cla>
      <cda>0.6417112299</cda>
      <cma>0</cma>
      <alpha_stall>0.192</alpha_stall>
      <cla_stall>-3.85</cla_stall>
      <cda_stall>-0.9233984055</cda_stall>
      <cma_stall>0</cma_stall>
      <!-- Wing AC moved 5cm AFT of CoG for longitudinal static stability.
           Previously +0.30m → wing lift produced nose-up moment → divergent
           pitch loop during transition (log 13_23_13 crash). With cp behind
           CoG, lift creates nose-down restoring moment as AoA increases. -->
      <cp>-0.05 0 0</cp>
      <area>0.265</area>
      <a0>-0.056</a0>
      <upward>0 0 1</upward>
      <forward>1 0 0</forward>
      <link_name>base_link</link_name>
    </plugin>

    <!-- ==================== Odometry / pose publishers ==================== -->
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <odom_frame>world</odom_frame>
      <robot_base_frame>stallion_vtol</robot_base_frame>
      <odom_publish_frequency>250</odom_publish_frequency>
      <dimensions>3</dimensions>
      <odom_topic>odometry</odom_topic>
    </plugin>
    <plugin filename="gz-sim-pose-publisher-system"
            name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <publish_sensor_pose>false</publish_sensor_pose>
      <publish_model_pose>true</publish_model_pose>
      <publish_nested_model_pose>false</publish_nested_model_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <static_publisher>false</static_publisher>
      <update_frequency>250</update_frequency>
    </plugin>

  </model>
</sdf>
