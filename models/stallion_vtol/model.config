<?xml version="1.0"?>
<model>
  <name>Stallion VTOL Tiltrotor</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>Stalya</name>
  </author>
  <description>
    Y-form tiltrotor VTOL (Stallion V2). Two front tilting rotors
    (rotor 0 right CW, rotor 1 left CCW) and one fixed tail rotor
    (rotor 2 CCW) for hover lift; stopped in FW cruise.
    Motors: T-Motor F90 28065 1300KV + HQProp 7x4x3 + 6S.
    MTOW: 3100 g. Wingspan: 1.34 m. Airfoil: Eppler E205.
  </description>
</model>
